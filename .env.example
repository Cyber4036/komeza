# Komeza - AI Mental Wellness Companion
# Copy this file to .env.local and add your Anthropic API key

# Server-side only — never exposed to the browser.
# Set this in Vercel project settings under Environment Variables.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local dev: set to "true" to route through /api/chat instead of demo mode.
# Requires `vercel dev` instead of `npm run dev`.
# VITE_USE_API=true

# Firebase — enables Google sign-in and Firestore cloud sync.
# Without these the app runs in localStorage-only mode (no accounts).
# Setup: https://console.firebase.google.com → new project → Web app
# Enable: Authentication → Google provider, Firestore Database
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
